apiVersion: v1
kind: Config
current-context: homelab
clusters:
- name: homelab
  cluster:
    server: https://192.168.2.12:6443
    certificate-authority-data: 
contexts:
- name: homelab
  context:
    cluster: homelab
    user: oidc
users:
- name: oidc
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1
      command: kubectl-oidc_login
      args:
        - get-token
        - --oidc-issuer-url=https://constantan.cloudflareaccess.com/cdn-cgi/access/sso/oidc/bc93fce5cbc6849f90972675c2279f70110d54b48eea203136686eb16e665d75
        - --oidc-client-id=bc93fce5cbc6849f90972675c2279f70110d54b48eea203136686eb16e665d75
        - --oidc-pkce-method=S256
        - --oidc-extra-scope=email
        - --oidc-extra-scope=profile
        - --oidc-extra-scope=groups
      interactiveMode: IfAvailable
